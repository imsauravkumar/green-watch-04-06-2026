# ========================
# Frontend .gitignore
# React + Vite App
# ========================

# ── Dependencies ────────────────────────────────
node_modules/

# ── Environment Variables ────────────────────────
.env
.env.*
!.env.example

# ── Build Output ────────────────────────────────
dist/
build/
out/

# ── Vite Cache ──────────────────────────────────
.vite/
vite.config.js.timestamp*

# ── Logs ────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS & Editor ─────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ── Misc ────────────────────────────────────────
.cache/
.eslintcache
*.tsbuildinfo
*.local

# ── Test Coverage ────────────────────────────────
coverage/
