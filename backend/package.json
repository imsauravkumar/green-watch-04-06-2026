{
  "name": "green-watch-backend",
  "version": "1.0.0",
  "description": "Green Watch backend server",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "kill": "for /f \"tokens=5\" %a in ('netstat -ano ^| findstr :5000') do taskkill /F /PID %a",
    "fresh": "npm run kill & npm run dev"
  },
  "dependencies": {
    "bcryptjs": "^3.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.8.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  }
}
