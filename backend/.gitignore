# ========================
# Backend .gitignore
# Node.js / Express API
# ========================

# ── Dependencies ────────────────────────────────
node_modules/

# ── Environment Variables ────────────────────────
.env
.env.*
!.env.example

# ── Logs ────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Database / Sensitive Data ────────────────────
db.json
*.dump
*.sqlite
*.sqlite3

# ── Firebase Admin SDK keys ──────────────────────
*serviceAccount*.json
firebase-admin*.json
*-firebase-adminsdk-*.json

# ── OS & Editor ─────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ── Build ────────────────────────────────────────
dist/
build/

# ── Coverage ────────────────────────────────────
coverage/
.nyc_output/
